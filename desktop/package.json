{
  "name": "git-helper-desktop",
  "version": "0.2.3",
  "private": true,
  "description": "Desktop shell (Electron) for Git Helper — full local-git experience.",
  "main": "main.cjs",
  "scripts": {
    "start": "npm --prefix .. run desktop:build && electron .",
    "start:fast": "electron .",
    "dist": "npm --prefix .. run desktop:build && electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.alphavima.githelper",
    "productName": "Git Helper",
    "asar": false,
    "files": [
      "main.cjs",
      "server.cjs",
      "dist/**/*",
      "mcp/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Abhialphavima007",
        "repo": "Git-Helper",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "identity": null
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    }
  }
}
