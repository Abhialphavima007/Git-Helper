{
  "name": "git-helper-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop shell (Electron) for Git Helper — full local-git experience.",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.alphavima.githelper",
    "productName": "Git Helper",
    "asar": false,
    "files": ["main.cjs", "server.cjs", "dist/**/*", "package.json"],
    "directories": { "output": "release" },
    "win": { "target": "nsis" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true },
    "mac": { "target": "dmg", "category": "public.app-category.developer-tools" },
    "linux": { "target": "AppImage", "category": "Development" }
  }
}
